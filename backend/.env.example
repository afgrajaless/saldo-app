# ─────────────────────────────────────────────
# Variables de entorno del backend (Saldo API)
# Copia este archivo a .env y completa los valores reales.
# El archivo .env real NUNCA se versiona (ver .gitignore).
# ─────────────────────────────────────────────

# Entorno de ejecucion
NODE_ENV=development
PORT=3000

# Base de datos — PostgreSQL en Neon (https://neon.com)
# Connection string del panel de Neon (boton "Connect").
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# JWT — Autenticacion (minimo 16 caracteres cada secreto)
# Genera secretos fuertes con: openssl rand -base64 48
JWT_ACCESS_SECRET=changeme_access_secret_min_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_refresh_secret_min_16_chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origen permitido del frontend
CORS_ORIGIN=http://localhost:8080
