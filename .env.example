# ─────────────────────────────────────────────
# Plantilla de variables de entorno (Backend)
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas el archivo .env real al repositorio.
# ─────────────────────────────────────────────

# Entorno de ejecución
NODE_ENV=development
PORT=3000

# Base de datos — PostgreSQL en Neon
# Connection string desde el panel de Neon (https://neon.com)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# JWT — Autenticación
# Genera secretos fuertes, p. ej: openssl rand -base64 48
JWT_ACCESS_SECRET=changeme_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origen permitido del frontend
CORS_ORIGIN=http://localhost:8080

# Open Finance — proveedor de datos bancarios
# 'mock' (default) usa datos de ejemplo; 'belvo' usa el adaptador real (sandbox).
OPEN_FINANCE_PROVIDER=mock
# Credenciales de Belvo (solo si OPEN_FINANCE_PROVIDER=belvo). Sandbox gratis en belvo.com
BELVO_BASE_URL=https://sandbox.belvo.com
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=

# Observabilidad — Sentry (opcional)
SENTRY_DSN=
